import java.sql.*;
import java.util.Scanner;

public class Payment {

    public static void pay(Connection conn, Scanner sc)
            throws SQLException {

        System.out.print("Reservation ID: ");
        int reservationId = sc.nextInt();
        sc.nextLine();

        String getPrice =
            "SELECT * FROM payments WHERE id=?";

        PreparedStatement pst1 =
            conn.prepareStatement(getPrice);

        pst1.setInt(1, reservationId);

        ResultSet rs = pst1.executeQuery();

        if(!rs.next()) {
            System.out.println("Reservation not found!");
            return;
        }

        double amount = rs.getDouble("price");

        System.out.println("=== PAYMENT METHODS ===");
        System.out.println("1. Cash");
        System.out.println("2. GCash");
        System.out.println("3. Credit Card");

        System.out.print("Choose Payment Method: ");
        int choice = sc.nextInt();
        sc.nextLine();

        String method = "";

        switch(choice) {

            case 1:
                method = "Cash";
                break;

            case 2:
                method = "GCash";
                break;

            case 3:
                method = "Credit Card";
                break;

            default:
                System.out.println("Invalid choice!");
                return;
        }

        String sql =
            "INSERT INTO payments " +
            "(reservation_id, payment_method, amount, payment_status) " +
            "VALUES (?, ?, ?, ?)";

        PreparedStatement pst =
            conn.prepareStatement(sql);

        pst.setInt(1, reservationId);
        pst.setString(2, method);
        pst.setDouble(3, amount);
        pst.setString(4, "PAID");

        pst.executeUpdate();

        System.out.println("Payment Successful!");
        System.out.println("Amount Paid: ₱" + amount);

        printReceipt(reservationId, method, amount);
    }

    public static void printReceipt(
            int reservationId,
            String method,
            double amount) {

        System.out.println("\n========= RECEIPT =========");
        System.out.println("Reservation ID: " + reservationId);
        System.out.println("Payment Method: " + method);
        System.out.println("Amount Paid: ₱" + amount);
        System.out.println("Status: PAID");
        System.out.println("===========================");
    }
}
