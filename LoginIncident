import java.sql.*;
import java.util.Scanner;

public class LogIncident {
    public static void record(Connection conn, Scanner sc) throws SQLException {
        System.out.print("Pet ID: ");
        int petId = sc.nextInt();
        sc.nextLine();

        System.out.print("Description: ");
        String desc = sc.nextLine();

        System.out.print("Date: ");
        String date = sc.nextLine();

        String sql = "INSERT INTO incidents (pet_id, description, date) VALUES (?, ?, ?)";
        PreparedStatement pst = conn.prepareStatement(sql);
        pst.setInt(1, petId);
        pst.setString(2, desc);
        pst.setString(3, date);
        pst.executeUpdate();

        System.out.println("Incident Logged!");
    }

    public static void viewMyLogIncidents(Connection conn, int userId) throws SQLException {
    String sql = "SELECT i.*, p.pet_name FROM incidents i " +
                 "JOIN pets p ON i.pet_id = p.id " +
                 "WHERE p.user_id = ?";
                 
    PreparedStatement pst = conn.prepareStatement(sql);
    pst.setInt(1, userId);
    ResultSet rs = pst.executeQuery();

    System.out.println("\n=== MY INCIDENTS ===");
    while (rs.next()) {
        System.out.println("Pet Name: " + rs.getString("pet_name"));
        System.out.println("Description: " + rs.getString("description"));
        System.out.println("Date: " + rs.getString("date"));
        System.out.println("-------------------");
    }
}
}
